# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables d'environnement requises
# Copier en .env et remplir les valeurs réelles (ne jamais committer .env)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=worldcup
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=worldcup2026

# Registry (pour la CI)
REGISTRY=ghcr.io
IMAGE_NAME=OWNER/worldcup-app
IMAGE_TAG=latest
